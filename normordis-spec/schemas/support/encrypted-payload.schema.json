{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://normordis.local/spec/schemas/support/encrypted-payload.schema.json",
  "title": "EncryptedPayload",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "algorithm", "nonce_b64", "ciphertext_b64", "kdf"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "algorithm": {
      "type": "string",
      "enum": ["XCHACHA20-POLY1305"],
      "description": "Algoritmo de cifra simétrica autenticada. Novos algoritmos requerem incremento MINOR da spec."
    },
    "key_id": { "type": "string", "minLength": 1 },
    "nonce_b64": { "type": "string", "minLength": 1 },
    "ciphertext_b64": { "type": "string", "minLength": 1 },
    "kdf": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "memory_kib", "iterations", "parallelism", "salt_b64"],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["external-key", "argon2id"],
          "description": "external-key: chave fornecida externamente (ex: DPAPI); argon2id: derivação a partir de senha."
        },
        "memory_kib": { "type": "integer", "minimum": 0 },
        "iterations": { "type": "integer", "minimum": 0 },
        "parallelism": { "type": "integer", "minimum": 0 },
        "salt_b64": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "algorithm": { "const": "argon2id" } },
            "required": ["algorithm"]
          },
          "then": {
            "properties": {
              "salt_b64": { "minLength": 1 },
              "memory_kib": { "minimum": 64 },
              "iterations": { "minimum": 1 },
              "parallelism": { "minimum": 1 }
            }
          }
        }
      ]
    }
  }
}
