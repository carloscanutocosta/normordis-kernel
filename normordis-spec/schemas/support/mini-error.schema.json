{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://normordis.local/spec/schemas/support/mini-error.schema.json",
  "title": "MiniError",
  "$defs": {
    "ErrorCode": {
      "type": "string",
      "pattern": "^MINI\\.[A-Z0-9_.]+$",
      "description": "Código canónico de erro: prefixo MINI. seguido de segmentos em maiúsculas separados por ponto."
    },
    "Component": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S+$",
      "description": "Nome do componente sem espaços (ex: core-audit, adapter-sqlite, core-config)."
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["code", "component", "message", "details"],
  "properties": {
    "code": { "$ref": "#/$defs/ErrorCode" },
    "component": { "$ref": "#/$defs/Component" },
    "message": { "type": "string", "minLength": 1 },
    "details": {}
  }
}
