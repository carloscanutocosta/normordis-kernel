{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://normordis.local/spec/schemas/core/validation/validation-result.schema.json",
  "title": "ValidationResult",
  "description": "Artefacto institucional de validação com identidade, contexto e outcomes por regra. Campos Option<T> sem skip_serializing_if serializam como null. Mapeado de core_validation::ValidationResult.",
  "type": "object",
  "additionalProperties": false,
  "required": ["validation_id", "target_type", "target_id", "overall_status", "outcomes"],
  "properties": {
    "validation_id": { "type": "string", "minLength": 1, "pattern": "^\\S(?:.*\\S)?$" },
    "target_type": { "type": "string", "minLength": 1, "pattern": "^\\S(?:.*\\S)?$" },
    "target_id": { "type": "string", "minLength": 1, "pattern": "^\\S(?:.*\\S)?$" },
    "context": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["timestamp_rfc3339"],
      "properties": {
        "actor_id": { "type": ["string", "null"], "minLength": 1 },
        "scope": { "type": ["string", "null"], "minLength": 1 },
        "timestamp_rfc3339": { "type": "string", "format": "date-time" },
        "engine_version": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "overall_status": {
      "type": "string",
      "enum": ["passed", "failed", "warning", "skipped", "not_applicable", "overridden", "execution_error"]
    },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule_id", "status"],
        "properties": {
          "rule_id": { "type": "string", "minLength": 1, "pattern": "^\\S(?:.*\\S)?$" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "warning", "skipped", "not_applicable", "overridden", "execution_error"]
          },
          "message": { "type": ["string", "null"], "minLength": 1 }
        }
      }
    }
  }
}
