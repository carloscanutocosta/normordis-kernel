{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://normordis.local/spec/schemas/core/security/policy.schema.json",
  "title": "Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["policy_id", "version", "mode", "rules"],
  "properties": {
    "policy_id": { "type": "string", "minLength": 1, "pattern": "^\\S(?:.*\\S)?$" },
    "version": { "type": "string", "minLength": 1, "pattern": "^\\S+$" },
    "mode": { "type": "string", "enum": ["baseline", "strict"] },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "enabled"],
        "properties": {
          "code": { "type": "string", "minLength": 1, "pattern": "^\\S(?:.*\\S)?$" },
          "enabled": { "type": "boolean" },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "valid_from": { "type": "string", "format": "date-time" },
    "valid_to": { "type": "string", "format": "date-time" }
  }
}
