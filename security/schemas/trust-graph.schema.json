{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://normordis.local/security/schemas/trust-graph.schema.json",
  "title": "NORMORDIS Trust Graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "project", "nodes", "edges"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["Draft", "Active", "Deprecated"]
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "description"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "relation"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "relation": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
